PORT=3000
NODE_ENV=development

# Spotify credentials.
# Defaults to the shared vibecheck app (predates Nov 2024 API restrictions).
# Only set these if you want to override with your own Spotify Developer app.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional: Beatport login for authenticated playlist scraping
BEATPORT_EMAIL=
BEATPORT_PASSWORD=
